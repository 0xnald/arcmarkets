# Get a free WalletConnect Project ID at https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Goldsky subgraph URL — set this AFTER deploying the subgraph
# (see arcmarkets-subgraph/README.md for deploy instructions)
# Without this, the app falls back to direct RPC reads (slower, no leaderboard/PnL)
NEXT_PUBLIC_SUBGRAPH_URL=

# Optional: override the public Arc RPC if you want to use a private one
# NEXT_PUBLIC_ARC_RPC_URL=
