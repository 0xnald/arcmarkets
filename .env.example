# Get a free WalletConnect Project ID at https://cloud.reown.com
# Without this, RainbowKit will still work for browser wallets (MetaMask, etc.)
# but mobile WalletConnect QR-code connections won't work.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Optional: override the public Arc RPC if you want to use a private one (Alchemy, Quicknode, etc.)
# Defaults to https://rpc.testnet.arc.network
# NEXT_PUBLIC_ARC_RPC_URL=
